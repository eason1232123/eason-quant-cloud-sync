# Local IBKR TWS / IB Gateway read-only bridge. No credentials belong here.
IBKR_HOST=127.0.0.1
# Pin one port when multiple sessions run. For run_v6_live_cycle only, unset or use "auto"
# to discover exactly one standard loopback Gateway/TWS port.
IBKR_PORT=7497
IBKR_CLIENT_ID=71
IBKR_TIMEOUT_SECONDS=15
IBKR_PRIVATE_SNAPSHOT=private/ibkr/account_snapshot.json
