{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/eason-quant/live_review_response.schema.json",
  "title": "V6 private ChatGPT live-review response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "request_id",
    "input_context_sha256",
    "reviewed_at_utc",
    "reviewer",
    "privacy",
    "checks",
    "conclusion",
    "automatic_order_allowed",
    "human_confirmation_required",
    "order_payload"
  ],
  "properties": {
    "schema_version": {"const": "v6-private-live-review-response-v1"},
    "status": {"const": "CHATGPT_LIVE_REVIEW_COMPLETED"},
    "request_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "input_context_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reviewed_at_utc": {"type": "string", "format": "date-time"},
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "model_id"],
      "properties": {
        "system": {"enum": ["CHATGPT", "CODEX"]},
        "model_id": {"type": "string", "minLength": 1, "maxLength": 200}
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "git_publish_allowed", "contains_private_account_reasoning"],
      "properties": {
        "classification": {"const": "PRIVATE_LOCAL_ONLY"},
        "git_publish_allowed": {"const": false},
        "contains_private_account_reasoning": {"const": true}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "status", "finding", "evidence_sources"],
        "properties": {
          "check_id": {
            "enum": ["live_quote", "market_regime", "fresh_news_macro", "earnings_valuation", "actual_account_risk", "execution_feasibility"]
          },
          "status": {"enum": ["PASS", "FAIL", "UNAVAILABLE"]},
          "finding": {"type": "string", "minLength": 1, "maxLength": 4000},
          "evidence_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_name", "source_type", "source_url", "observed_at_utc", "market_timezone", "data_kind"],
              "properties": {
                "source_name": {"type": "string", "minLength": 1, "maxLength": 300},
                "source_type": {
                  "enum": ["IBKR_TWS", "PUBLIC_MARKET_DATA", "PUBLIC_NEWS", "PUBLIC_FILINGS", "GITHUB_EVIDENCE", "PRIVATE_CONTEXT"]
                },
                "source_url": {
                  "anyOf": [
                    {"type": "string", "format": "uri"},
                    {"type": "null"}
                  ]
                },
                "observed_at_utc": {"type": "string", "format": "date-time"},
                "market_timezone": {"type": "string", "minLength": 1},
                "data_kind": {
                  "enum": [
                    "INTRADAY_REALTIME_BID_ASK",
                    "INTRADAY_REALTIME_LAST",
                    "INTRADAY_DELAYED",
                    "END_OF_DAY_ADJUSTED",
                    "END_OF_DAY_UNADJUSTED",
                    "NEWS_OR_MACRO",
                    "FUNDAMENTAL_OR_VALUATION",
                    "PRIVATE_ACCOUNT_SNAPSHOT",
                    "GITHUB_QUANT_EVIDENCE",
                    "UNKNOWN_NOT_USED_FOR_BUY"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "conclusion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "symbol", "confidence", "reason_codes", "summary"],
      "properties": {
        "action": {"enum": ["NO_TRADE", "WAIT", "REDUCE_REVIEW", "BUY_REVIEW"]},
        "symbol": {
          "anyOf": [
            {"type": "string", "pattern": "^[A-Z0-9.-]+$"},
            {"type": "null"}
          ]
        },
        "confidence": {"enum": ["LOW", "MEDIUM", "HIGH"]},
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z0-9_]+$"}
        },
        "summary": {"type": "string", "minLength": 1, "maxLength": 4000}
      }
    },
    "automatic_order_allowed": {"const": false},
    "human_confirmation_required": {"const": true},
    "order_payload": {"type": "null"}
  }
}
